# =====================================================
# Ayora - Variables d'environnement (exemple)
# =====================================================
# Copiez ce fichier vers `.env` ou definissez ces
# variables dans votre systeme avant de lancer Tomcat.
#
# Aucun secret ne doit etre committe dans git.
# Le fichier .env est ignore via .gitignore.

# ----- SMTP (envoi des invitations par email) -----
# Si AYORA_MAIL_FROM ou AYORA_MAIL_PASSWORD sont vides,
# l'EmailService bascule en MODE DEMO (simulation, log
# uniquement, aucun mail reel envoye).
AYORA_SMTP_HOST=smtp.gmail.com
AYORA_SMTP_PORT=587
AYORA_MAIL_FROM=votre.email@gmail.com
AYORA_MAIL_PASSWORD=mot-de-passe-application-google
AYORA_MAIL_SENDER=Ayora - Mariage

# ----- Notes pour Gmail -----
# 1. Activez la double authentification sur votre compte Google
# 2. Generez un "App password" : https://myaccount.google.com/apppasswords
# 3. Utilisez ce mot de passe d'application (16 caracteres) ici, PAS votre mot
#    de passe Google habituel.

# ----- Sous Eclipse (Tomcat run config) -----
# Window > Preferences > Server > Runtime Environments > Edit > Tomcat
# Onglet "Environment" > Add :
#    AYORA_MAIL_FROM = ...
#    AYORA_MAIL_PASSWORD = ...

# ----- En ligne de commande (catalina.bat) -----
# set AYORA_MAIL_FROM=...
# set AYORA_MAIL_PASSWORD=...
# catalina.bat run
